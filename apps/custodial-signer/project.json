{
  "name": "custodial-signer",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/custodial-signer",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "root": "apps/custodial-signer",
        "outputPath": "dist/apps/custodial-signer"
      },
      "configurations": {
        "development": {
          "outputPath": "apps/custodial-signer"
        },
        "production": {}
      }
    },
    "serve": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "custodial-signer:build",
        "dev": true,
        "port": 4202
      },
      "configurations": {
        "development": {
          "buildTarget": "custodial-signer:build:development",
          "dev": true
        },
        "production": {
          "buildTarget": "custodial-signer:build:production",
          "dev": false
        }
      }
    },
    "export": {
      "executor": "@nx/next:export",
      "options": {
        "buildTarget": "custodial-signer:build:production"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/custodial-signer/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/custodial-signer/**/*.{ts,tsx,js,jsx}"]
      }
    },
    "version": {
      "executor": "@jscutlery/semver:version",
      "options": {
        "preset": "conventional",
        "skipRootChangelog": true,
        "skipProjectChangelog": true
      }
    }
  },
  "tags": []
}
