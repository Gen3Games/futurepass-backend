{
  "name": "gen3-signer-backend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/gen3-signer-backend/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "target": "node",
        "compiler": "tsc",
        "outputPath": "dist/apps/gen3-signer-backend",
        "main": "apps/gen3-signer-backend/src/main.ts",
        "tsConfig": "apps/gen3-signer-backend/tsconfig.app.json",
        "generatePackageJson": false
      },
      "configurations": {
        "development": {},
        "production": {
          "optimization": true,
          "extractLicenses": true,
          "inspect": false
        }
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "gen3-signer-backend:build"
      },
      "configurations": {
        "production": {
          "buildTarget": "gen3-signer-backend:build:production"
        }
      }
    },
    "lint": {
      "executor": "@nx/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/gen3-signer-backend/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/gen3-signer-backend/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "tags": []
}