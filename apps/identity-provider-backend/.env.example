# FuturePass Identity Provider - Self-Custody Auth Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# Server Configuration
# =============================================================================

# Port to run the server on
PORT=4200

# Node environment (development, staging, production)
NODE_ENV=development

# =============================================================================
# OIDC Configuration
# =============================================================================

# The issuer URL (must be HTTPS in production)
OIDC_ISSUER=https://login.futureverse.dev

# JSON Web Key Set for signing tokens
# Generate with: npx node -e "const jose = require('jose'); (async () => { const { publicKey, privateKey } = await jose.generateKeyPair('RS256'); console.log(JSON.stringify({ keys: [await jose.exportJWK(privateKey)] })) })()"
OIDC_KEYSTORE={"keys":[]}

# =============================================================================
# Blockchain Configuration
# =============================================================================

# Chain IDs for Root Network
# Mainnet: 7672
# Testnet (Porcini): 7672
ETH_CHAIN_ID=7672
EVM_CHAIN_ID=7672

# RPC URLs
TRN_RPC_URL=https://root.rootnet.live/

# =============================================================================
# Security
# =============================================================================

# Secret for CSRF token generation (generate a secure random string)
CSRF_SECRET=your-csrf-secret-change-this

# Secret for session cookies (generate a secure random string)
SESSION_SECRET=your-session-secret-change-this

# =============================================================================
# AWS DynamoDB Configuration
# =============================================================================

# AWS Region
AWS_REGION=ap-southeast-2

# DynamoDB table names
DYNAMODB_USER_TABLE=futureverse-user
DYNAMODB_OIDC_TABLE=oidc-sessions

# Local development endpoint for ScyllaDB Alternator
DYNAMODB_ENDPOINT=http://localhost:8000

# Local development credentials for Alternator
AWS_ACCESS_KEY_ID=alternator
AWS_SECRET_ACCESS_KEY=alternator

# =============================================================================
# Redis Configuration (for caching)
# =============================================================================

REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=fp:
REDIS_CACHE_TTL=3600

# =============================================================================
# External Services
# =============================================================================

# Account indexer API for FuturePass lookups
DELEGATED_ACCOUNT_INDEXER_API_BASE_URL=https://indexer.futureverse.app

# =============================================================================
# Frontend Configuration
# =============================================================================

# URL of the login frontend (for redirects)
FRONTEND_URL=https://login.futureverse.dev

# =============================================================================
# Development Settings
# =============================================================================

# Enable dev interactions in OIDC provider (for debugging)
OIDC_DEV_MODE=true

# =============================================================================
# Optional: Pre-registered OAuth Clients
# =============================================================================

# Default client for development/testing
# OIDC_CLIENT_ID=demo-client
# OIDC_CLIENT_SECRET=demo-secret
# OIDC_CLIENT_REDIRECT_URI=http://localhost:3000/callback
