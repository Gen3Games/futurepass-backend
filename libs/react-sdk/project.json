{
  "name": "react-sdk",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/react-sdk/src",
  "projectType": "library",
  "targets": {
    "lint": {
      "executor": "@nx/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/react-sdk/**/*.{ts,tsx}"],
        "ignorePath": "libs/react-sdk/.eslintignore"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/react-sdk/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "build": {
      "executor": "@nx/rollup:rollup",
      "dependsOn": ["^build"],
      "outputs": ["{options.outputPath}"],
      "options": {
        "compiler": "babel",
        "rollupConfig": "libs/react-sdk/rollup.config.cjs",
        "outputPath": "dist/libs/react-sdk",
        "tsConfig": "libs/react-sdk/tsconfig.lib.json",
        "project": "libs/react-sdk/package.json",
        "main": "libs/react-sdk/index.ts",
        "buildableProjectDepsInPackageJsonType": "dependencies",
        "updateBuildableProjectDepsInPackageJson": true,
        "assets": [
          {
            "glob": "libs/react-sdk/README.md",
            "input": ".",
            "output": "."
          }
        ],
        "format": ["esm", "cjs"],
        "external": "all"
      }
    },
    "version": {
      "executor": "@jscutlery/semver:version",
      "options": {
        "preset": "conventional",
        "skipRootChangelog": true,
        "skipProjectChangelog": true
      }
    }
  },
  "tags": []
}
