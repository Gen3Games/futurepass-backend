  "scripts": {
    "prepare": "husky install",
    "commit": "cz",
    "test": "pnpm exec nx run-many --target=test",
    "build:all": "pnpm exec nx run-many --target=build && ./update-generated-package-json.sh",
    "build:dev:libs": "NODE_ENV=development pnpm exec nx run-many --target=build --projects=experience-sdk,identity-contract-bindings,nx-tools,oidc-client,react-sdk,rpc-kit,stateboss && ./update-generated-package-json.sh",
    "build:libs": "pnpm exec nx run-many --target=build --projects=experience-sdk,identity-contract-bindings,nx-tools,oidc-client,react-sdk,rpc-kit,stateboss && ./update-generated-package-json.sh",
    "build:sdks": "pnpm exec nx run-many --target=build --projects=experience-sdk,react-sdk && ./update-generated-package-json.sh",
    "build:identity-provider-frontend": "pnpm exec nx build identity-provider-frontend",
    "dev:identity-provider-frontend": "pnpm exec nx serve identity-provider-frontend --configuration=development",
    "dev:identity-provider-backend": "./apps/identity-provider-backend/startup.sh ./apps/identity-provider-backend/docker-compose.yaml",
    "dev:identity-provider": "./run-identity-provider.sh ./apps/identity-provider-backend/docker-compose.yaml",
    "publish:identity-provider-backend": "pnpm exec nx container identity-provider-backend --prod && apps/identity-provider-backend/ecr_push.sh",
    "howto:build:identity-provider-frontend": "echo 'Usage: pnpm build:identity-provider-frontend --configuration=[preview|neptune|staging|production|audit]'",
    "codegen-compile": "graphql-codegen",
    "exec:script": "TS_NODE_COMPILER_OPTIONS='{\"noUnusedLocals\": false}' node -r tsconfig-paths/register -r ts-node/register",
    "createLDFlag": "pnpm exec node ./apps/identity-provider-backend/src/scripts/createLaunchdarklyFlag.mjs",
    "deleteLDFlag": "pnpm exec node ./apps/identity-provider-backend/src/scripts/deleteLaunchdarklyFlag.mjs",
    "publish-lib": "node ./scripts/packagePublishing/prepublish.js"
  },
